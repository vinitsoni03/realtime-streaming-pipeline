# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,jsx,tsx,json,css,scss,md}]
indent_size = 2

[*.{sh,py,rb}]
indent_size = 4

[Makefile]
indent_style = tab
